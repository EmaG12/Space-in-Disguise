
bool frecciaUscitaAttiva = false;
function region1_WalksOnto(Region *theRegion)
{
  player.ChangeRoom(2, 243, 130);
}

function on_mouse_click(MouseButton button)
{
  if (button == eMouseLeft)
  {
    // --- CASO 1: Ingresso verso il villaggio (L'enigma del buio) ---
    if (Hotspot.GetAtScreenXY(mouse.x, mouse.y) == hIngressoVillaggio)
    {
      if (player.ActiveInventory == null)
      {
        ClaimEvent(); // Blocca l'apertura della ruota

        // Cammina verso il cunicolo (sostituisci X e Y)
        player.Walk(280, 110, eBlock, eWalkableAreas); 

        // Va nella stanza buia
        player.Say("Vediamo dove andiamo.");
        player.Transparency = 100;
        player.ChangeRoom(5); 
      }
    }

    // --- CASO 2: Ritorno al deserto (Nessun enigma, usa l'altra funzione) ---
    else if (Hotspot.GetAtScreenXY(mouse.x, mouse.y) == hUscita_Caverna)
    {
      if (player.ActiveInventory == null)
      {
        ClaimEvent(); // Blocca l'apertura della ruota

        // Converte il click in un semplice comando di camminata, 
        // in modo che il personaggio raggiunga l'area/region che innesca il cambio stanza
        Room.ProcessClick(mouse.x, mouse.y, eModeWalkto);
      }
    }
  }
}

function room_RepExec()
{
  // AGS memorizza in automatico l'hotspot che stai puntando
  Hotspot* hSottoMouse = Hotspot.GetAtScreenXY(mouse.x, mouse.y);

  // 
  if (hSottoMouse == hUscita_Caverna) //
  {
    if (frecciaUscitaAttiva == false)
    {
      mouse.SaveCursorUntilItLeaves();
      mouse.UseModeGraphic(eModeExitLeft);
      frecciaUscitaAttiva = true;
    }
  }
  
  // --- USCITA 2 (Opzionale: es. verso sinistra nella stessa stanza) ---
  // else if (hSottoMouse == hUscita_Deserto) 
  // {
  //   if (frecciaUscitaAttiva == false)
  //   {
  //     mouse.SaveCursorUntilItLeaves();
  //     mouse.UseModeGraphic(eModeExitLeft); 
  //     frecciaUscitaAttiva = true;
  //   }
  // }
  
  // --- RESET GENERALE ---
  else
  {
    frecciaUscitaAttiva = false;
  }
}

function room_Load()
{
cEsploratore.FaceDirection(eDirectionRight);
}

function room_AfterFadeIn()
{
  cHT.FaceDirection(eDirectionRight);    
  aCaverna.Play(eAudioPriorityNormal, eRepeat);
  if(Game.DoOnceOnly("CutsceneIniziale"))
  {
    gActionBar.Visible = false;
    StartCutscene(eSkipESCOnly);
    // --- 1. PICCOLA CUTSCENE INIZIALE ---
    
    // Il protagonista parla da solo
    cHT.Say("Ehi... c'è nessuno in questa caverna?");
    Wait(40); // Pausa di circa un secondo
    // L'alieno risponde
   
    Game.SpeechFont = 4;
    cEsploratore.Say("La mia ex mi ha lasciato per un irlandese ed ora lei si è lasciata, GODO");
    Game.SpeechFont = 1;
    cHT.Say("Ehm, forse dovrei avvicinarmi");
    
    
    player.Walk(cEsploratore.x - 35,  cEsploratore.y,  eBlock, eWalkableAreas);
    player.FaceCharacter(cEsploratore,  eBlock);
    cEsploratore.FaceCharacter(cHT, eBlock);
    
    // --- 2. AVVIO DEL DIALOGO A SCELTE MULTIPLE ---
    
    // Questo comando apre l'interfaccia con le opzioni che hai creato prima
    gActionBar.Visible = true;
    dIncontroCaverna.Start();
    EndCutscene();
  }
}
function room_Unload()
{
aCaverna.Stop();
}

function hIngressoVillaggio_UseInv(Hotspot *theHotspot, CursorMode mode)
{
  if (player.ActiveInventory == iGeoMappa) 
  {
    player.Walk(281,  103, eBlock, eWalkableAreas);
    player.Say("Attivo la Geo-Mappa... mi mostra un percorso sicuro per evitare cuniculi");
  
    player.ChangeRoom(4,  1235,  234); 
  }
  else 
  {
    player.Say("Questo oggetto non mi aiuta a trovare la strada corretta.");
  }
}


