
bool frecciaUscitaAttiva = false;
function region1_WalksOnto(Region *theRegion)
{
  player.ChangeRoom(2, 243, 130);
}

function on_mouse_click(MouseButton button)
{
  if (button == eMouseLeft)
  {
   
    if (Hotspot.GetAtScreenXY(mouse.x, mouse.y) == hUscita_Caverna)
    {
      
      ClaimEvent(); 
      
      
      Room.ProcessClick(mouse.x, mouse.y, eModeWalkto);
    }
  }
}

function room_RepExec()
{
  // AGS memorizza in automatico l'hotspot che stai puntando
  Hotspot* hSottoMouse = Hotspot.GetAtScreenXY(mouse.x, mouse.y);

  // 
  if (hSottoMouse == hUscita_Caverna) //
  {
    if (frecciaUscitaAttiva == false)
    {
      mouse.SaveCursorUntilItLeaves();
      mouse.UseModeGraphic(eModeExitLeft);
      frecciaUscitaAttiva = true;
    }
  }
  
  // --- USCITA 2 (Opzionale: es. verso sinistra nella stessa stanza) ---
  // else if (hSottoMouse == hUscita_Deserto) 
  // {
  //   if (frecciaUscitaAttiva == false)
  //   {
  //     mouse.SaveCursorUntilItLeaves();
  //     mouse.UseModeGraphic(eModeExitLeft); 
  //     frecciaUscitaAttiva = true;
  //   }
  // }
  
  // --- RESET GENERALE ---
  else
  {
    frecciaUscitaAttiva = false;
  }
}

function room_Load()
{
cEsploratore.FaceDirection(eDirectionRight);

}



function room_AfterFadeIn()
{
      
  gActionBar.Visible = false;
aCaverna.Play(eAudioPriorityNormal, eRepeat);

  if(Game.DoOnceOnly("CutsceneIniziale"))
  {
    StartCutscene(eSkipESCOnly);
    // --- 1. PICCOLA CUTSCENE INIZIALE ---
    
    // Il protagonista parla da solo
    cHT.Say("Ehi... c'è nessuno in questa caverna?");
    Wait(40); // Pausa di circa un secondo
    // L'alieno risponde
    cEsploratore.Say("Chi osa disturbare il mio riposo?");
    
    cHT.Say("Ehm, sono letteralmente un alieno in incognito, vengo in pace!");
    
     player.Walk(cEsploratore.x - 35,  cEsploratore.y,  eBlock, eWalkableAreas);
    player.FaceCharacter(cEsploratore,  eBlock);
    cEsploratore.FaceCharacter(cHT, eBlock);
    
    // --- 2. AVVIO DEL DIALOGO A SCELTE MULTIPLE ---
    
    // Questo comando apre l'interfaccia con le opzioni che hai creato prima
    gActionBar.Visible = true;
    EndCutscene();
    QuestEsploratore = true;
    dHeilHitler.Start();
  }
}


function room_Unload()
{
aCaverna.Stop();
}
