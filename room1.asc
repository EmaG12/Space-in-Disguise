// room script file
function room_AfterFadeIn()
{
    mouse.Visible = false;  
    StartCutscene(eSkipESCOnly);

    // 1. Inizia a suonare l'allarme (supponendo tu abbia un file audio chiamato 'aAllarme')
    aAllarme.Play(eAudioPriorityNormal, eRepeat);
    
    // 2. Il personaggio dice qualcosa mentre cade
    cHT.Say("Porco dio non funziona un cazzo, prepararsi all'impatto!");
    
    // 3. Ciclo per far lampeggiare lo schermo e tremare la navicella
    ShakeScreenBackground(5, 10, 240);
    int i = 0;
    while (i < 6) // Ripete il lampeggio 4 volte
    {
        gAllarme.Visible = true;        // Accende il rosso
        Wait(15);   
        gAllarme.Visible = false;       // Spegne il rosso
        Wait(10);                            // Pausa normale per mezzo secondo
        i++;
    }
 
    // 4. Lo schianto! Cambia istantaneamente stanza (es. in una stanza tutta nera) 
    // oppure riproduci direttamente il suono dell'esplosione
    aAllarme.Stop();
    Wait(10);
    aSchianto.Play();
    
    // Dissolvenza incrociata al bianco o al nero per simulare la perdita di sensi
    FadeOut(40);
    Wait(400);
    
    EndCutscene();

    // 5. Sposta il giocatore nel Deserto (es. Room 2)
    
    
    player.ChangeRoom(2, 86, 153); 
    mouse.Visible = true; 
}


