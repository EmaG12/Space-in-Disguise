// room script file
bool frecciaUscitaAttiva = false;

function Navicella_Look(Hotspot *theHotspot, CursorMode mode)
{
player.Say("Porco dio la mia navicella e' distrutta. Gua di merda");
}

function on_mouse_click(MouseButton button)
{
  if (button == eMouseLeft)
  {
   
    if (Hotspot.GetAtScreenXY(mouse.x, mouse.y) == hCaverna)
    {
      
      ClaimEvent(); 
      
      
      Room.ProcessClick(mouse.x, mouse.y, eModeWalkto);
    }
  }
}

function region1_WalksOnto(Region *theRegion)
{
// Il giocatore entra nella grotta
    mouse.SetPosition(160,  160);
    lblAction.Text = "";
    Wait(1);
    player.ChangeRoom(3, 76, 152);
    
}


function cambio_cursore()
{
  if (GUI.GetAtScreenXY(mouse.x, mouse.y) != null || IsGamePaused()) 
  {
    frecciaUscitaAttiva = false; // Resettiamo la variabile per sicurezza
    return; // Il comando 'return' blocca la funzione qui. Il codice sottostante non verrà letto!
  }
  // AGS memorizza in automatico l'hotspot che stai puntando
  Hotspot* hSottoMouse = Hotspot.GetAtScreenXY(mouse.x, mouse.y);

  
  if (hSottoMouse == hCaverna) //
  {
    if (frecciaUscitaAttiva == false)
    {
      mouse.SaveCursorUntilItLeaves();
      mouse.UseModeGraphic(eModeExitRight);
      frecciaUscitaAttiva = true;
    }
  }
  
  // --- USCITA 2 (Opzionale: es. verso sinistra nella stessa stanza) ---
  // else if (hSottoMouse == hUscita_Deserto) 
  // {
  //   if (frecciaUscitaAttiva == false)
  //   {
  //     mouse.SaveCursorUntilItLeaves();
  //     mouse.UseModeGraphic(eModeExitLeft); 
  //     frecciaUscitaAttiva = true;
  //   }
  // }
  
  // --- RESET GENERALE ---
  else
  {
    frecciaUscitaAttiva = false;
  }
}

function Navicella_PickUp(Hotspot *theHotspot, CursorMode mode)
{
    if (player.HasInventory(iAllarme))
    {
        player.Say("Ho già preso quello che mi serviva, non rimettero' le mani lì dentro.");
    }
    else if (QuestEsploratore == true)
    {
        player.Walk(135,  148, eBlock);
        player.FaceDirection(eDirectionUp);
        gMinigioco.Visible = true;
    }
    else 
    {
        player.Say("Non penso proprio che mi entrerebbe una navicella intera nello zaino.");
    }
}



function Navicella_Talk(Hotspot *theHotspot, CursorMode mode)
{
player.Say("Ciao, come stai?... Ha visto giorni migliori, probabilmente anche io...");
}

function Navicella_UseInv(Hotspot *theHotspot, CursorMode mode)
{

}

function room_AfterFadeIn()
{
  aAudioRoom2.Play(eAudioPriorityNormal, eRepeat);
}

function room_Unload()
{
  aAudioRoom2.Stop();
}
